DATABASE_URL=postgresql+asyncpg://hcmis:hcmis@localhost:15432/hcmis
REDIS_URL=redis://localhost:16379/0
JWT_SECRET_KEY=change-me
BRIDGE_AGENT_KEY=change-me-bridge-key
BRIDGE_DEVICE_TIMEZONE=Asia/Manila
ENVIRONMENT=development
SHARED_RESOURCES_STORAGE_DIR=./storage/shared-resources
SHARED_RESOURCES_MAX_FILE_SIZE_MB=50
PROFILE_PHOTOS_STORAGE_BACKEND=filesystem
PROFILE_PHOTOS_STORAGE_DIR=./storage/profile-photos
PROFILE_PHOTOS_MAX_FILE_SIZE_MB=5
# Optional public base URL for filesystem mode (example: https://api.example.com)
PROFILE_PHOTOS_PUBLIC_BASE_URL=
# S3 settings used when PROFILE_PHOTOS_STORAGE_BACKEND=s3
PROFILE_PHOTOS_S3_BUCKET=your_bucket_name
PROFILE_PHOTOS_S3_REGION=ap-southeast-1
PROFILE_PHOTOS_S3_ENDPOINT_URL=https://your-project-ref.storage.supabase.co/storage/v1/s3
PROFILE_PHOTOS_S3_ACCESS_KEY_ID=your_s3_access_key_id
PROFILE_PHOTOS_S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
# Optional CDN/base URL for S3 object access (example: https://cdn.example.com)
PROFILE_PHOTOS_S3_PUBLIC_BASE_URL=
PROFILE_PHOTOS_S3_PREFIX=profile-photos
PROFILE_PHOTOS_SIGNED_URL_TTL_SECONDS=900
